    <skos:notation>FDT6087</skos:notation>
    <skos:prefLabel xml:lang="fr">Publication issue de l'étude et présentant les résultats de la recherche (articles, posters, rapports, ouvrages ou chapitres...).</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Publication resulting from the study and presenting research findings (articles, posters, reports, books or chapters, etc.).</skos:prefLabel>
  </rdf:Description>
