  <skos:ConceptScheme rdf:about="https://portail-fresh.fr/vocab/FDT">
      <dct:creator rdf:resource="https://portail-fresh.fr/"/>
      <dct:description xml:lang="en">Terms used to describe the field 'DocumentType' in the FReSH metadata schema.</dct:description>
      <dct:description xml:lang="fr">Concepts utilisés pour décrire le champ 'DocumentType' du schéma de métadonnées FReSH.</dct:description>
