    <skos:notation>FDT6755</skos:notation>
    <skos:prefLabel xml:lang="fr">Publication réutilisant les données collectées dans le cadre de cette étude.</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Publication reusing data collected in this study.</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FDT#FDT4538">
