      <dct:title xml:lang="en">Document type</dct:title>
      <dct:title xml:lang="fr">Type de document</dct:title>
      <pav:createdOn>2026-01-05</pav:createdOn>
      <pav:lastUpdatedOn>2020-04-16</pav:lastUpdatedOn>
    </skos:ConceptScheme>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FDT#FDT6755">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FDT"/>
    <skos:notation>FDT6755</skos:notation>
    <skos:prefLabel xml:lang="fr">Publication réutilisant les données collectées dans le cadre de cette étude.</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Publication reusing data collected in this study.</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FDT#FDT4538">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FDT"/>
    <skos:notation>FDT4538</skos:notation>
    <skos:prefLabel xml:lang="fr">Publication définissant la base de données et/ou son protocole de collecte (data paper, cohort profile, method/protocol paper, resource paper, data note, registered report...).</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Publication defining the database and/or its collection protocol  (data paper, cohort profile, method/protocol paper, resource paper, data note, registered report...).</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FDT#FDT6087">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FDT"/>
    <skos:notation>FDT6087</skos:notation>
    <skos:prefLabel xml:lang="fr">Publication issue de l'étude et présentant les résultats de la recherche (articles, posters, rapports, ouvrages ou chapitres...).</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Publication resulting from the study and presenting research findings (articles, posters, reports, books or chapters, etc.).</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FDT#FDT6296">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FDT"/>
    <skos:notation>FDT6296</skos:notation>
    <skos:prefLabel xml:lang="fr">Protocole de l'étude.</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Study protocol.</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FDT">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    <dct:title xml:lang="fr">DocumentType</dct:title>
