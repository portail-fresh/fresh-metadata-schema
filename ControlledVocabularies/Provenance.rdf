  <skos:ConceptScheme rdf:about="https://portail-fresh.fr/vocab/FPV">
      <dct:creator rdf:resource="https://portail-fresh.fr/"/>
      <dct:description xml:lang="en">Terms used to describe the field 'Provenance' in the FReSH metadata schema.</dct:description>
      <dct:description xml:lang="fr">Concepts utilisés pour décrire le champ 'Provenance' du schéma de métadonnées FReSH.</dct:description>
