<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
 xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
 xmlns:dct="http://purl.org/dc/terms/"
 xmlns:pav="http://purl.org/pav/"
 xmlns:skos="http://www.w3.org/2004/02/skos/core#">
  <skos:ConceptScheme rdf:about="https://portail-fresh.fr/vocab/FTP">
      <dct:creator rdf:resource="https://portail-fresh.fr/"/>
      <dct:description xml:lang="en">Terms used to describe the field 'TimePerspective' in the FReSH metadata schema.</dct:description>
      <dct:description xml:lang="fr">Concepts utilisés pour décrire le champ 'TimePerspective' du schéma de métadonnées FReSH.</dct:description>
      <dct:rights rdf:resource="https://creativecommons.org/licenses/by-nc-sa/4.0/"/>
      <dct:title xml:lang="en">Time perspective</dct:title>
      <dct:title xml:lang="fr">Perspective temporelle</dct:title>
      <pav:createdOn>2026-01-05</pav:createdOn>
      <pav:lastUpdatedOn>2020-04-16</pav:lastUpdatedOn>
    </skos:ConceptScheme>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FTP#FTP8482">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FTP"/>
    <skos:notation>FTP8482</skos:notation>
    <skos:prefLabel xml:lang="fr">Longitudinale rétrospective</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Retrospective longitudinal</skos:prefLabel>
    <skos:definition xml:lang="fr">Inclusion des participants à partir de données existantes recueillies dans le passé.</skos:definition>
    <skos:definition xml:lang="en">Inclusion of participants based on existing data collected in the past.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FTP#FTP3385">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FTP"/>
    <skos:notation>FTP3385</skos:notation>
    <skos:prefLabel xml:lang="fr">Etude transversale non répétée</skos:prefLabel>
    <skos:prefLabel xml:lang="en">One-time cross-sectional study</skos:prefLabel>
    <skos:definition xml:lang="fr">Observation à un moment donné d’une population, sans suivi actif dans le temps.</skos:definition>
    <skos:definition xml:lang="en">One-time observation of a population, without an active follow-up.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FTP#FTP2932">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FTP"/>
    <skos:notation>FTP2932</skos:notation>
    <skos:prefLabel xml:lang="fr">Etude transversale répétée </skos:prefLabel>
    <skos:prefLabel xml:lang="en">Repeated cross-sectional study</skos:prefLabel>
    <skos:definition xml:lang="fr">Observations répétées à différents moments sur des échantillons indépendants.</skos:definition>
    <skos:definition xml:lang="en">Repeated observations at different times on independent samples.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FTP">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    <dct:title xml:lang="fr">RecrutementTiming</dct:title>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FTP#FTP1434">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FTP"/>
    <skos:notation>FTP1434</skos:notation>
    <skos:prefLabel xml:lang="fr">Longitudinale prospective</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Prospective longitudinal</skos:prefLabel>
    <skos:definition xml:lang="fr">Inclusion des participants suivis dans le temps à partir de leur entrée dans l’étude.</skos:definition>
    <skos:definition xml:lang="en">Inclusion of participants followed over time from their entry into the study.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FTP#FTP2406">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FTP"/>
    <skos:notation>FTP2406</skos:notation>
    <skos:prefLabel xml:lang="fr">Autre</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Other</skos:prefLabel>
    <skos:definition xml:lang="fr">À utiliser lorsque le type de recrutement est connu, mais introuvable dans la liste.</skos:definition>
    <skos:definition xml:lang="en">Used when the inclusion type is known but cannot be found in the list.</skos:definition>
  </rdf:Description>
</rdf:RDF>
