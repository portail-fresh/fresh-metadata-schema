    <skos:notation>FRS1358</skos:notation>
    <skos:prefLabel xml:lang="fr">Base de population à finalité statistique</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Population database for statistical purposes</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FRS#FRS1139">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FRS"/>
    <skos:notation>FRS1139</skos:notation>
