    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FRS"/>
    <skos:notation>FRS8956</skos:notation>
    <skos:prefLabel xml:lang="fr">Base administrative (d'employés, d'élèves, d'étudiants, etc…)</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Administrative database (employees, pupils, students, etc.)</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FRS#FRS1358">
