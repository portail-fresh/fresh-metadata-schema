  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FRS#FRS1139">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FRS"/>
    <skos:notation>FRS1139</skos:notation>
    <skos:prefLabel xml:lang="fr">Via des structures (services ou établissements de santé, écoles, entreprises…)</skos:prefLabel>
