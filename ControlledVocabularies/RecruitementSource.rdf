    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FRS"/>
    <skos:notation>FRS3712</skos:notation>
    <skos:prefLabel xml:lang="fr">Base médico-administrative (de patients, Assurance Maladie/Mutuelle)</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Medical-administrative database (patients, health insurance/mutual insurance)</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FRS#FRS8098">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FRS"/>
    <skos:notation>FRS8098</skos:notation>
    <skos:prefLabel xml:lang="fr">Via les professionnels de santé d'exercice libéral</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Through independent healthcare practitioners</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FRS#FRS2933">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FRS"/>
    <skos:notation>FRS2933</skos:notation>
    <skos:prefLabel xml:lang="fr">Autre</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Other</skos:prefLabel>
    <skos:definition xml:lang="fr">À utiliser lorsque la source du recrutement est connue, mais introuvable dans la liste.</skos:definition>
    <skos:definition xml:lang="en">Use when the recrutment source is known but cannot be found in the list.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FRS">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    <dct:title xml:lang="fr">RecruitementSource</dct:title>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FRS#FRS8956">
