<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
 xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
 xmlns:dct="http://purl.org/dc/terms/"
 xmlns:pav="http://purl.org/pav/"
 xmlns:skos="http://www.w3.org/2004/02/skos/core#">
  <skos:ConceptScheme rdf:about="https://portail-fresh.fr/vocab/FPT">
      <dct:creator rdf:resource="https://portail-fresh.fr/"/>
      <dct:description xml:lang="en">Terms used to describe the field 'PopulationType' in the FReSH metadata schema.</dct:description>
      <dct:description xml:lang="fr">Concepts utilisés pour décrire le champ 'PopulationType' du schéma de métadonnées FReSH.</dct:description>
      <dct:rights rdf:resource="https://creativecommons.org/licenses/by-nc-sa/4.0/"/>
      <dct:title xml:lang="en">Population type</dct:title>
      <dct:title xml:lang="fr">Type de population</dct:title>
      <pav:createdOn>2026-01-05</pav:createdOn>
      <pav:lastUpdatedOn>2020-04-16</pav:lastUpdatedOn>
    </skos:ConceptScheme>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FPT#FPT7356">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FPT"/>
    <skos:notation>FPT7356</skos:notation>
    <skos:prefLabel xml:lang="fr">Autre</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Other</skos:prefLabel>
    <skos:definition xml:lang="fr">À utiliser lorsque le type de population est connu, mais introuvable dans la liste.</skos:definition>
    <skos:definition xml:lang="en">Use when the population type is known but cannot be found in the list.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FPT#FPT2781">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FPT"/>
    <skos:notation>FPT2781</skos:notation>
    <skos:prefLabel xml:lang="fr">Population générale</skos:prefLabel>
    <skos:prefLabel xml:lang="en">General population</skos:prefLabel>
    <skos:definition xml:lang="fr">Ensemble des individus d'un territoire donné, indépendamment de leur état de santé ou de leur recours aux soins.</skos:definition>
    <skos:definition xml:lang="en">All individuals in a given area, regardless of their state of health or their use of healthcare.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FPT#FPT4254">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FPT"/>
    <skos:notation>FPT4254</skos:notation>
    <skos:prefLabel xml:lang="fr">Patients</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Patients population</skos:prefLabel>
    <skos:definition xml:lang="fr">Personnes ayant reçu un diagnostic médical et faisant l’objet d’un suivi ou d’une prise en charge dans le cadre du système de soins, qu’il soit ambulatoire ou hospitalier.</skos:definition>
    <skos:definition xml:lang="en">People who have received a medical diagnosis and are subject to follow-up or care within the healthcare system, whether outpatient or inpatient.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FPT#FPT5451">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="https://portail-fresh.fr/vocab/FPT"/>
    <skos:notation>FPT5451</skos:notation>
    <skos:prefLabel xml:lang="fr">Personnes en situation de handicap</skos:prefLabel>
    <skos:prefLabel xml:lang="en">People with disabilities</skos:prefLabel>
    <skos:definition xml:lang="fr">Personnes qui présentent des incapacités physiques, mentales, intellectuelles ou sensorielles durables qui limitent leur activité ou restreignent leur participation à la vie en société participation sur la base de l’égalité avec les autres.</skos:definition>
    <skos:definition xml:lang="en">Individuals with long-term physical, mental, intellectual, or sensory disabilities that limit their activity or restrict their participation in society on an equal basis with others.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://portail-fresh.fr/vocab/FPT">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    <dct:title xml:lang="fr">PopulationType</dct:title>
  </rdf:Description>
</rdf:RDF>
